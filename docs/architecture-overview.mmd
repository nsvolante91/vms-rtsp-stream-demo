%%{ init: { "theme": "base", "themeVariables": { "fontSize": "14px", "fontFamily": "Segoe UI, sans-serif" } } }%%

flowchart LR
  subgraph DOCKER["Docker / Test Environment"]
    direction TB
    style DOCKER fill:#e8d5f5,stroke:#7b2d8e,stroke-width:2px,color:#333
    FFmpeg["FFmpeg<br/>(loop test videos)"]
    MediaMTX["MediaMTX<br/>RTSP Server<br/>:8554"]
    FFmpeg -->|"RTSP/RTP<br/>TCP"| MediaMTX
  end

  subgraph BRIDGE["Bridge Server · Node.js / TypeScript"]
    direction TB
    style BRIDGE fill:#d5e8f5,stroke:#2d6b8e,stroke-width:2px,color:#333
    RTSPClient["RTSPClient<br/>(FFmpeg subprocess)"]
    H264Parser["H264Parser<br/>NAL extraction<br/>SPS decode"]
    StreamMgr["StreamManager<br/>subscription<br/>multiplexing"]
    RTSPClient --> H264Parser --> StreamMgr
    REST["REST API<br/>HTTP/1.1 :9000<br/>/streams · /cert-hash"]
    WT["WebTransport<br/>HTTP/3 QUIC :9001<br/>binary protocol"]
    WS["WebSocket<br/>TCP fallback<br/>/ws"]
    StreamMgr --> WT
    StreamMgr --> WS
  end

  subgraph CLIENT["Browser Client · TypeScript / Vite"]
    direction TB
    style CLIENT fill:#d5f5e0,stroke:#2d8e4a,stroke-width:2px,color:#333

    subgraph MAIN["Main Thread"]
      direction TB
      style MAIN fill:#c2e8cf,stroke:#2d8e4a,stroke-width:1px,color:#333
      VMSApp["VMSApp<br/>device detection<br/>CSS Grid layout"]
      Controls["Controls<br/>grid · streams<br/>upscale · compare"]
      Tiles["StreamTile[]<br/>canvas + overlay"]
      Dashboard["Dashboard<br/>MetricsCollector"]
      VMSApp --- Controls
      VMSApp --- Tiles
      VMSApp --- Dashboard
    end

    subgraph WORKER["Web Worker"]
      direction TB
      style WORKER fill:#b8dcc5,stroke:#2d8e4a,stroke-width:1px,color:#333
      WTRecv["WTReceiver<br/>binary protocol<br/>BYOB reader"]
      Pipeline["StreamPipeline<br/>per-stream orchestrator"]
      Demux["H264Demuxer<br/>Annex B → chunks"]
      Decoder["VideoDecoder<br/>WebCodecs HW accel<br/>backpressure"]
      Renderer["OffscreenRenderer<br/>rAF batch render"]
      WTRecv --> Pipeline --> Demux --> Decoder --> Renderer
    end

    MAIN <-->|"postMessage<br/>metrics · commands"| WORKER
  end

  MediaMTX -->|"RTSP/RTP<br/>TCP"| RTSPClient
  REST <-->|"HTTP/1.1<br/>JSON"| VMSApp
  WT -->|"HTTP/3 QUIC<br/>12B header + H.264"| WTRecv
  WS -.->|"WebSocket TCP<br/>binary frames"| WTRecv

  subgraph GPU["GPU Hardware"]
    direction TB
    style GPU fill:#fff3cd,stroke:#856404,stroke-width:2px,color:#333
    ExtTex["importExternalTexture<br/>zero-copy"]
    Shaders["Upscale Shaders<br/>10 modes"]
    ExtTex --> Shaders
  end

  Renderer -->|"WebGPU"| ExtTex

%%{ init: { "theme": "base", "themeVariables": { "fontSize": "13px", "fontFamily": "Segoe UI, sans-serif" } } }%%

flowchart TB
  subgraph MAIN["Main Thread"]
    direction TB
    style MAIN fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#333

    VMSApp["VMSApp\ndevice detection · stream lifecycle"]
    DeviceProfile["DeviceProfile\nmobile: maxStreams=4, DPR≤2\ndesktop: maxStreams=16, DPR≤3"]

    VMSApp --> DeviceProfile

    subgraph UI["UI Layer"]
      direction LR
      style UI fill:#bbdefb,stroke:#1565c0,stroke-width:1px,color:#333
      Controls["Controls\ngrid layout · +/- streams\nupscale mode · compare toggle"]
      GridLayout["CSS Grid\n1×1 / 2×2 / 3×3 / 4×4"]
      Controls --- GridLayout
    end

    subgraph TILES["Stream Tiles"]
      direction LR
      style TILES fill:#bbdefb,stroke:#1565c0,stroke-width:1px,color:#333
      Tile1["StreamTile 1\ncanvas + overlay"]
      Tile2["StreamTile 2\ncanvas + overlay"]
      TileN["StreamTile N\ncanvas + overlay"]
      Tile1 ~~~ Tile2 ~~~ TileN
    end

    subgraph PERF["Performance"]
      direction LR
      style PERF fill:#bbdefb,stroke:#1565c0,stroke-width:1px,color:#333
      Metrics["MetricsCollector\nFPS · latency · memory"]
      Dash["Dashboard\nreal-time overlay"]
      Bench["BenchmarkRunner\nauto stream scaling"]
      Metrics --- Dash
      Metrics --- Bench
    end

    VMSApp --> UI
    VMSApp --> TILES
    VMSApp --> PERF
  end

  MAIN <-->|"postMessage\ninit · addStream · removeStream\nresize · setUpscale · setZoom\nmetrics · connected · error"| WORKER

  subgraph WORKER["Web Worker"]
    direction TB
    style WORKER fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#333

    subgraph TRANSPORT["Transport Layer"]
      direction LR
      style TRANSPORT fill:#c8e6c9,stroke:#2e7d32,stroke-width:1px,color:#333
      WTRecv["WTReceiver\nHTTP/3 QUIC\nBYOB reader\nauto-reconnect"]
      WSRecv["WSReceiver\nWebSocket TCP\nfallback"]
      WTRecv ~~~ WSRecv
    end

    subgraph DECODE["Decode Pipeline  (per stream)"]
      direction TB
      style DECODE fill:#c8e6c9,stroke:#2e7d32,stroke-width:1px,color:#333
      SPipeline["StreamPipeline\norchestrator"]
      Demux["H264Demuxer\nAnnex B → NALs\nSPS/PPS → codec string\n→ EncodedVideoChunk"]
      VDecoder["VideoDecoder\nWebCodecs HW accel\nbackpressure: drop B@3, non-KF@4"]
      SPipeline --> Demux --> VDecoder
    end

    subgraph RENDER["Render Engine"]
      direction TB
      style RENDER fill:#c8e6c9,stroke:#2e7d32,stroke-width:1px,color:#333

      RAFLoop["rAF Render Loop\nbatch all streams\nsingle GPU submit"]
      OffRenderer["OffscreenRenderer\nOffscreenCanvas per stream"]

      RAFLoop --> OffRenderer

      subgraph WEBGPU_PATH["WebGPU Path"]
        direction TB
        style WEBGPU_PATH fill:#a5d6a7,stroke:#2e7d32,stroke-width:1px,color:#333
        ImportTex["importExternalTexture\nVideoFrame → GPUExternalTexture\nvalid until microtask end"]
        Upscale["Upscale Shaders"]
        GPUSub["queue.submit()\nthen frame.close()"]
        ImportTex --> Upscale --> GPUSub
      end

      subgraph UPSCALE_MODES["Upscale Modes"]
        direction LR
        style UPSCALE_MODES fill:#a5d6a7,stroke:#2e7d32,stroke-width:1px,color:#333
        M1["off\n(passthrough)"]
        M2["CAS\n(sharpening)"]
        M3["FSR\n(edge-aware)"]
        M4["Anime4K\n(CNN)"]
        M5["Lanczos\n(compute)"]
        M6["TSR\n(temporal)"]
        M7["Spectral\n(frequency)"]
        M8["VQSR\n(learned SR)"]
        M9["Generative\n(detail synth)"]
        M10["DLSS\n(temporal+spatial)"]
      end

      subgraph CANVAS2D_PATH["Canvas2D Fallback"]
        direction TB
        style CANVAS2D_PATH fill:#fff3e0,stroke:#e65100,stroke-width:1px,color:#333
        DrawImage["drawImage(VideoFrame)\nletterbox/pillarbox\nthen frame.close()"]
      end

      OffRenderer --> WEBGPU_PATH
      OffRenderer -.-> CANVAS2D_PATH
      Upscale --> UPSCALE_MODES
    end

    TRANSPORT --> DECODE
    VDecoder -->|"VideoFrame"| RAFLoop
  end

%%{ init: { "theme": "base", "themeVariables": { "fontSize": "13px", "fontFamily": "Segoe UI, sans-serif" } } }%%

flowchart TB
  subgraph MAIN["Main Thread"]
    direction TB
    style MAIN fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#333

    VMSApp["VMSApp<br/>device detection · stream lifecycle"]
    DeviceProfile["DeviceProfile<br/>mobile: maxStreams=4, DPR≤2<br/>desktop: maxStreams=16, DPR≤3"]

    VMSApp --> DeviceProfile

    subgraph UI["UI Layer"]
      direction LR
      style UI fill:#bbdefb,stroke:#1565c0,stroke-width:1px,color:#333
      Controls["Controls<br/>grid layout · +/- streams<br/>upscale mode · compare toggle"]
      GridLayout["CSS Grid<br/>1×1 / 2×2 / 3×3 / 4×4"]
      Controls --- GridLayout
    end

    subgraph TILES["Stream Tiles"]
      direction LR
      style TILES fill:#bbdefb,stroke:#1565c0,stroke-width:1px,color:#333
      Tile1["StreamTile 1<br/>canvas + overlay"]
      Tile2["StreamTile 2<br/>canvas + overlay"]
      TileN["StreamTile N<br/>canvas + overlay"]
      Tile1 ~~~ Tile2 ~~~ TileN
    end

    subgraph PERF["Performance"]
      direction LR
      style PERF fill:#bbdefb,stroke:#1565c0,stroke-width:1px,color:#333
      Metrics["MetricsCollector<br/>FPS · latency · memory"]
      Dash["Dashboard<br/>real-time overlay"]
      Bench["BenchmarkRunner<br/>auto stream scaling"]
      Metrics --- Dash
      Metrics --- Bench
    end

    VMSApp --> UI
    VMSApp --> TILES
    VMSApp --> PERF
  end

  MAIN <-->|"postMessage<br/>init · addStream · removeStream<br/>resize · setUpscale · setZoom<br/>metrics · connected · error"| WORKER

  subgraph WORKER["Web Worker"]
    direction TB
    style WORKER fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#333

    subgraph TRANSPORT["Transport Layer"]
      direction LR
      style TRANSPORT fill:#c8e6c9,stroke:#2e7d32,stroke-width:1px,color:#333
      WTRecv["WTReceiver<br/>HTTP/3 QUIC<br/>BYOB reader<br/>auto-reconnect"]
      WSRecv["WSReceiver<br/>WebSocket TCP<br/>fallback"]
      WTRecv ~~~ WSRecv
    end

    subgraph DECODE["Decode Pipeline  (per stream)"]
      direction TB
      style DECODE fill:#c8e6c9,stroke:#2e7d32,stroke-width:1px,color:#333
      SPipeline["StreamPipeline<br/>orchestrator"]
      Demux["H264Demuxer<br/>Annex B → NALs<br/>SPS/PPS → codec string<br/>→ EncodedVideoChunk"]
      VDecoder["VideoDecoder<br/>WebCodecs HW accel<br/>backpressure: drop B@3, non-KF@4"]
      SPipeline --> Demux --> VDecoder
    end

    subgraph RENDER["Render Engine"]
      direction TB
      style RENDER fill:#c8e6c9,stroke:#2e7d32,stroke-width:1px,color:#333

      RAFLoop["rAF Render Loop<br/>batch all streams<br/>single GPU submit"]
      OffRenderer["OffscreenRenderer<br/>OffscreenCanvas per stream"]

      RAFLoop --> OffRenderer

      subgraph WEBGPU_PATH["WebGPU Path"]
        direction TB
        style WEBGPU_PATH fill:#a5d6a7,stroke:#2e7d32,stroke-width:1px,color:#333
        ImportTex["importExternalTexture<br/>VideoFrame → GPUExternalTexture<br/>valid until microtask end"]
        Upscale["Upscale Shaders"]
        GPUSub["queue.submit()<br/>then frame.close()"]
        ImportTex --> Upscale --> GPUSub
      end

      subgraph UPSCALE_MODES["Upscale Modes"]
        direction LR
        style UPSCALE_MODES fill:#a5d6a7,stroke:#2e7d32,stroke-width:1px,color:#333
        M1["off<br/>(passthrough)"]
        M2["CAS<br/>(sharpening)"]
        M3["FSR<br/>(edge-aware)"]
        M4["Anime4K<br/>(CNN)"]
        M5["Lanczos<br/>(compute)"]
        M6["TSR<br/>(temporal)"]
        M7["Spectral<br/>(frequency)"]
        M8["VQSR<br/>(learned SR)"]
        M9["Generative<br/>(detail synth)"]
        M10["DLSS<br/>(temporal+spatial)"]
      end

      subgraph CANVAS2D_PATH["Canvas2D Fallback"]
        direction TB
        style CANVAS2D_PATH fill:#fff3e0,stroke:#e65100,stroke-width:1px,color:#333
        DrawImage["drawImage(VideoFrame)<br/>letterbox/pillarbox<br/>then frame.close()"]
      end

      OffRenderer --> WEBGPU_PATH
      OffRenderer -.-> CANVAS2D_PATH
      Upscale --> UPSCALE_MODES
    end

    TRANSPORT --> DECODE
    VDecoder -->|"VideoFrame"| RAFLoop
  end

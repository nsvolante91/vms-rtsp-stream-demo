# Bridge Server Configuration
# Copy this file to .env and modify as needed.

# HTTP REST API port (default: 9000)
BRIDGE_PORT=9000

# WebTransport (HTTP/3 QUIC) port (default: 9001)
WT_PORT=9001

# RTSP base URL for stream discovery (default: rtsp://localhost:8554)
# For local MediaMTX: rtsp://localhost:8554
# For a real IP camera: rtsp://admin:password@192.168.1.100:554/stream
RTSP_BASE_URL=rtsp://localhost:8554
